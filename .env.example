# Copy this file to .env and replace empty values. Never commit .env.
# This file is sourced by Bash: quote values containing shell metacharacters and
# percent-encode special characters in database credentials.

# Host ports. Container-to-container addresses are fixed in services/docker-compose.yaml.
API_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
# Local shell launch stays on loopback; Compose overrides this to 0.0.0.0 inside
# the isolated container network and still publishes the host port on 127.0.0.1.
MLFLOW_HOST=127.0.0.1
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# External PostgreSQL backend for MLflow metadata.
# Use URL-encoding for special characters in the username/password and require TLS
# when the provider supports it. Example (do not reuse these placeholders):
# postgresql+psycopg2://USER:PASSWORD@DB_HOST:5432/DB_NAME?sslmode=require
MLFLOW_BACKEND_STORE_URI=

# Third-party S3-compatible artifact storage. The destination must start with s3://.
# Examples of endpoints are https://storage.yandexcloud.net or the endpoint supplied
# by your object-storage provider. Do not put credentials into either URL.
MLFLOW_ARTIFACTS_DESTINATION=
MLFLOW_S3_ENDPOINT_URL=
MLFLOW_S3_IGNORE_TLS=false
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional for temporary credentials and providers with a custom CA certificate.
AWS_SESSION_TOKEN=
AWS_CA_BUNDLE=
